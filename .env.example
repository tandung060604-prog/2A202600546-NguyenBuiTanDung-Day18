# cp .env.example .env
# Required for M4 (RAGAS eval) and M5 / answer generation
# Option 1: OpenAI
OPENAI_API_KEY=sk-...

# Option 2: Gemini via OpenAI-compatible endpoint
GEMINI_API_KEY=
GOOGLE_API_KEY=
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
ANSWER_MODEL=gemini-2.5-flash-lite
ENRICHMENT_MODEL=gemini-2.5-flash-lite
ENABLE_OPENAI_ANSWER=1
ENABLE_OPENAI_ENRICHMENT=1
